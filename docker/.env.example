# Database Configuration
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=your_secure_mongo_password
MONGO_PASSWORD=your_secure_mongo_password

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_minimum_32_characters_long

# Application URLs
CLIENT_URL=https://yourdomain.com
SERVER_URL=https://yourdomain.com/api

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Mapbox Configuration
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Monitoring Configuration
GRAFANA_PASSWORD=your_grafana_admin_password

# Development Environment Variables
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://admin:your_secure_mongo_password@localhost:27017/proprender?authSource=admin
REDIS_URL=redis://:your_secure_redis_password@localhost:6379

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your_session_secret_key_minimum_32_characters_long

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# SSL Configuration (for production)
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your_backup_bucket
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY=your_s3_access_key
BACKUP_S3_SECRET_KEY=your_s3_secret_key

# Analytics Configuration
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
GOOGLE_TAG_MANAGER_ID=GTM_CONTAINER_ID

# Social Media Configuration
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Push Notifications
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=your_email@yourdomain.com

# Feature Flags
ENABLE_MULTI_LANGUAGE=true
ENABLE_DARK_MODE=true
ENABLE_REAL_TIME_NOTIFICATIONS=true
ENABLE_ADVANCED_SEARCH=true
ENABLE_VIRTUAL_TOURS=true
ENABLE_AI_RECOMMENDATIONS=false

# Third-party Integrations
ZILLOW_API_KEY=your_zillow_api_key
GOOGLE_PLACES_API_KEY=your_google_places_api_key
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Security Configuration
BCRYPT_SALT_ROUNDS=12
SESSION_TIMEOUT_MS=3600000
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MS=900000

# Development Tools
ENABLE_MONGO_EXPRESS=true
ENABLE_REDIS_COMMANDER=true
ENABLE_PROMETHEUS=true
ENABLE_GRAFANA=true

# Testing Configuration
TEST_DATABASE_URL=mongodb://admin:test_password@localhost:27017/proprender_test
TEST_REDIS_URL=redis://localhost:6379/1

# Performance Configuration
NODE_OPTIONS=--max-old-space-size=2048
UV_THREADPOOL_SIZE=128

# Error Reporting
SENTRY_DSN=your_sentry_dsn
ROLLBAR_ACCESS_TOKEN=your_rollbar_access_token
